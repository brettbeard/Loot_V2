<ContentDialog
    x:Class="Loot_V2.Views.BudgetItemPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="New Month"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <Grid MinWidth="540">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Month / Year selectors -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <ComboBox x:Name="MonthCombo" Header="Month" Width="150"/>
            <ComboBox x:Name="YearCombo"  Header="Year"  Width="100"/>
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Margin="0,0,0,8"/>

        <!-- Select All / Select None buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Select All"  Click="OnSelectAllClicked"/>
            <Button Content="Select None" Click="OnSelectNoneClicked"/>
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="3" Margin="36,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Name"   FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="1" Text="Type"   FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="2" Text="Amount" FontWeight="SemiBold" FontSize="12" Margin="8,0,0,0"/>
            <TextBlock Grid.Column="3" Text="Day"    FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
        </Grid>

        <!-- Item list -->
        <ScrollViewer Grid.Row="4" MaxHeight="300">
            <ItemsControl x:Name="ItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Item.Name}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TypeDisplay}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox Grid.Column="3"
                                       Value="{Binding EditAmount, Mode=TwoWay}"
                                       Minimum="0" SmallChange="1"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="4"
                                       Text="{Binding Item.DayOfMonth}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</ContentDialog>
