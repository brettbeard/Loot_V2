<ContentDialog
    x:Class="Loot_V2.Views.AddEditBudgetItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="320">
        <TextBox x:Name="NameBox" Header="Name" PlaceholderText="e.g. Rent"/>
        <NumberBox x:Name="AmountBox" Header="Amount" PlaceholderText="0.00"
                   Minimum="0"
                   SpinButtonPlacementMode="Inline"
                   SmallChange="1" LargeChange="10"/>
        <CheckBox x:Name="IsCreditBox" Content="Is Credit / Income"/>
        <NumberBox x:Name="DayBox" Header="Day of Month (1–31)"
                   Minimum="1" Maximum="31" Value="1"
                   SpinButtonPlacementMode="Inline" SmallChange="1"/>
    </StackPanel>
</ContentDialog>
