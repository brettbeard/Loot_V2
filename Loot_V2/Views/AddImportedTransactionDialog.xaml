<ContentDialog
    x:Class="Loot_V2.Views.AddImportedTransactionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Add Imported Transaction"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="360">
        <TextBox x:Name="NameBox" Header="Name (Payee)"/>
        <StackPanel Orientation="Horizontal" Spacing="24">
            <StackPanel Spacing="4">
                <TextBlock Text="Date" Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="DateText"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Amount" Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="AmountText"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Type" Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="TypeText"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</ContentDialog>
