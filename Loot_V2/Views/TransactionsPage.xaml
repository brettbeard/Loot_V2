<Page
    x:Class="Loot_V2.Views.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:Loot_V2.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
        <helpers:CurrencyConverter x:Key="AccountingConverter" Accounting="True"/>
        <helpers:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
    </Page.Resources>

    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="New Month" Click="OnNewMonthClicked"/>
            <Button Content="Open..." Click="OnOpenClicked"/>
            <Button Content="Save" Click="OnSaveClicked"
                    IsEnabled="{x:Bind ViewModel.HasMonth, Mode=OneWay}"/>
            <Button Content="Save As..." Click="OnSaveAsClicked"
                    IsEnabled="{x:Bind ViewModel.HasMonth, Mode=OneWay}"/>
        </StackPanel>

        <!-- Transactions DataGrid -->
        <controls:DataGrid
            Grid.Row="1"
            x:Name="TransactionsGrid"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            SelectionMode="Single"
            ItemsSource="{x:Bind ViewModel.Source, Mode=OneWay}"
            LoadingRow="OnLoadingRow"
            DoubleTapped="OnGridDoubleTapped"
            RightTapped="OnGridRightTapped"
            Sorting="OnGridSorting"
            Visibility="{x:Bind ViewModel.HasMonth, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
            <controls:DataGrid.Resources>
                <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent"/>
            </controls:DataGrid.Resources>
            <controls:DataGrid.Columns>
                <controls:DataGridTemplateColumn Header="Date" Tag="Date" Width="100" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Date, Converter={StaticResource DateOnlyConverter}}"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="Name" Tag="Name" Width="*" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="Amount" Tag="Amount" Width="120" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SignedAmount, Converter={StaticResource CurrencyConverter}}"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Status" Tag="Status" Binding="{Binding Status}" Width="110"/>
                <controls:DataGridTemplateColumn Header="Balance" Tag="RunningBalance" Width="130" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RunningBalance, Converter={StaticResource CurrencyConverter}}"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Empty state -->
        <TextBlock Grid.Row="1"
                   Text="No month loaded. Click 'New Month' to start, or 'Open...' to load a saved file."
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   TextWrapping="Wrap" Opacity="0.5" MaxWidth="400"
                   Visibility="{x:Bind ViewModel.HasMonth, Mode=OneWay, Converter={StaticResource BoolToCollapsed}}"/>

        <!-- Status bar -->
        <TextBlock Grid.Row="2"
                   Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                   Margin="0,4,0,0" FontSize="12" Opacity="0.6"/>

        <!-- Balance footer -->
        <Border Grid.Row="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="0,8,0,0"
                Visibility="{x:Bind ViewModel.HasMonth, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <TextBlock Text="Current Balance:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentBalance, Mode=OneWay, Converter={StaticResource AccountingConverter}}"
                           FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="120"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
