<Page
    x:Class="Loot_V2.Views.BudgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:Loot_V2.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
        <helpers:CurrencyConverter x:Key="AccountingConverter" Accounting="True"/>
        <helpers:CreditTypeConverter x:Key="CreditTypeConverter"/>
    </Page.Resources>

    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Add" Click="OnAddClicked"/>
            <Button Content="Edit" Click="OnEditClicked"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Delete" Click="OnDeleteClicked"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
        </StackPanel>

        <!-- Budget DataGrid -->
        <controls:DataGrid
            Grid.Row="1"
            x:Name="BudgetGrid"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            SelectionMode="Single"
            ItemsSource="{x:Bind ViewModel.Source, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            DoubleTapped="OnGridDoubleTapped"
            Sorting="OnGridSorting"
            RightTapped="OnGridRightTapped">
            <controls:DataGrid.Resources>
                <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent"/>
            </controls:DataGrid.Resources>
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Name" Tag="Name" Binding="{Binding Name}" Width="*"/>
                <controls:DataGridTemplateColumn Header="Type" Tag="IsCredit" Width="90" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsCredit, Converter={StaticResource CreditTypeConverter}}"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="Amount" Tag="Amount" Width="130" CanUserSort="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Amount, Converter={StaticResource CurrencyConverter}}"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Day of Month" Tag="DayOfMonth" Binding="{Binding DayOfMonth}" Width="120"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Monthly total footer -->
        <Border Grid.Row="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <TextBlock Text="Monthly Total:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.MonthlyTotal, Mode=OneWay, Converter={StaticResource AccountingConverter}}"
                           FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
